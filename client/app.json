{
  "expo": {
    "name": "to-do-list-expo",
    "slug": "to-do-list-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "to-do-list-expo",
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.to-do-list-expo",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.todolistexpo"
    },
    "web": {},
    "extra": {
      "eas": {
        "projectId": "281d42e3-c031-4602-8fd0-24190551f7b1"
      }
    },
    "plugins": [
      "expo-router",
      "@clerk/expo",
      "expo-secure-store"
    ]
  }
}
