{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Expo iOS (Start & Debug)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/client/node_modules/.bin/expo",
      "args": ["start", "--ios"],
      "cwd": "${workspaceFolder}/client",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
