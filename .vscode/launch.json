{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Expo iOS (Start & Debug)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/client/node_modules/.bin/expo",
      "args": ["start", "--ios"],
      "cwd": "${workspaceFolder}/client",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/server/node_modules/.bin/tsx",
      "runtimeArgs": ["watch", "server.ts"],
      "cwd": "${workspaceFolder}/server",
      "restart": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Server", "Expo iOS (Start & Debug)"]
    }
  ]
}
