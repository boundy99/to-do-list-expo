{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "expo-start-ios",
      "type": "shell",
      "command": "expo",
      "args": ["start", "--ios"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Expo server is running.*",
          "endsPattern": "^.*Ready.*"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
